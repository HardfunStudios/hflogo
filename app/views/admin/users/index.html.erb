<% content_for :page_title, "Usuários" %>

<div class="card-light" style="padding:24px;">
  <%= form_with url: admin_users_path, method: :get, local: true, class: "flex gap-2 mb-5" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Buscar por nome ou e-mail…",
        class: "form-input flex-1", style: "max-width:320px;" %>
    <%= f.submit "Buscar", class: "btn-primary", style: "font-size:14px;padding:6px 16px;" %>
    <% if params[:q].present? %>
      <%= link_to "Limpar", admin_users_path, style: "font-size:14px;color:#929292;padding:6px 12px;text-decoration:none;align-self:center;" %>
    <% end %>
  <% end %>

  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="border-bottom:2px solid #e5e5e5;">
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Usuário</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">E-mail</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Papel</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Status</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Cadastro</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |u| %>
        <tr style="border-top:1px solid #f0f0f0;">
          <td style="padding:10px 0;">
            <%= link_to u.display, admin_user_path(u), style: "font-weight:600;color:#000;text-decoration:none;" %>
            <br><span style="font-size:11px;color:#929292;">@<%= u.username %></span>
          </td>
          <td style="padding:10px 0;color:#929292;"><%= u.email %></td>
          <td style="padding:10px 0;">
            <span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;background:<%= u.admin? ? 'rgba(213,20,20,0.10)' : u.moderator? ? 'rgba(255,170,0,0.12)' : '#f5f5f5' %>;color:<%= u.admin? ? '#D51414' : u.moderator? ? '#B87A00' : '#929292' %>;">
              <%= u.role %>
            </span>
          </td>
          <td style="padding:10px 0;">
            <% if u.banned_at %>
              <span style="font-size:12px;color:#D51414;font-weight:600;">Banido</span>
            <% else %>
              <span style="font-size:12px;color:#0081A6;font-weight:600;">Ativo</span>
            <% end %>
          </td>
          <td style="padding:10px 0;color:#929292;"><%= u.created_at.strftime("%d/%m/%Y") %></td>
          <td style="padding:10px 0;text-align:right;">
            <%= link_to "Ver →", admin_user_path(u), style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:none;" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
