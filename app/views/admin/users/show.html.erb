<% content_for :page_title, "Usuário: #{@user.display}" %>

<div style="display:grid;grid-template-columns:280px 1fr;gap:24px;align-items:start;">
  <%# Info sidebar %>
  <div style="display:flex;flex-direction:column;gap:16px;">

    <div class="card-light" style="padding:24px;">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
        <% if @user.avatar_url.present? %>
          <img src="<%= @user.avatar_url %>" style="width:48px;height:48px;border-radius:50%;object-fit:cover;" alt="">
        <% else %>
          <div style="width:48px;height:48px;border-radius:50%;background:#0081A6;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:18px;">
            <%= @user.display.first.upcase %>
          </div>
        <% end %>
        <div>
          <div style="font-size:15px;font-weight:600;color:#000;"><%= @user.display %></div>
          <div style="font-size:12px;color:#929292;">@<%= @user.username %></div>
        </div>
      </div>
      <dl style="font-size:13px;display:flex;flex-direction:column;gap:10px;">
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">E-mail</dt><dd style="color:#000;"><%= @user.email %></dd></div>
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Papel</dt><dd><%= @user.role %></dd></div>
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Cadastro</dt><dd><%= @user.created_at.strftime("%d/%m/%Y") %></dd></div>
        <% if @user.banned_at %>
          <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Banido em</dt><dd style="color:#D51414;"><%= @user.banned_at.strftime("%d/%m/%Y") %></dd></div>
          <% if @user.banned_reason.present? %>
            <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Motivo</dt><dd><%= @user.banned_reason %></dd></div>
          <% end %>
        <% end %>
      </dl>
    </div>

    <div class="card-light" style="padding:20px;">
      <h3 style="font-size:14px;font-weight:600;color:#000;margin-bottom:12px;">Alterar papel</h3>
      <%= form_with url: admin_user_path(@user), method: :patch, local: true, class: "flex gap-2" do |f| %>
        <%= f.select :role, [["user","user"],["moderator","moderator"],["admin","admin"]], { selected: @user.role },
            style: "flex:1;border:1px solid #929292;border-radius:5px;padding:0 8px;height:36px;font-size:14px;font-family:'Montserrat',sans-serif;outline:none;" %>
        <button type="submit" class="btn-primary" style="font-size:13px;padding:6px 14px;">Salvar</button>
      <% end %>
    </div>

    <div class="card-light" style="padding:20px;">
      <h3 style="font-size:14px;font-weight:600;color:#000;margin-bottom:12px;">Alterar senha</h3>
      <%= form_with url: admin_user_path(@user), method: :patch, local: true, style: "display:flex;flex-direction:column;gap:8px;" do |f| %>
        <%= f.password_field :password, placeholder: "Nova senha…", class: "form-input" %>
        <button type="submit" class="btn-primary" style="font-size:13px;padding:6px 14px;justify-content:center;">Alterar senha</button>
      <% end %>
    </div>

    <div class="card-light" style="padding:20px;">
      <% if @user.banned_at %>
        <%= button_to "Remover ban", unban_admin_user_path(@user), method: :post,
            style: "width:100%;padding:8px;border-radius:6px;background:rgba(0,129,166,0.08);color:#0081A6;border:2px solid #0081A6;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;" %>
      <% else %>
        <h3 style="font-size:14px;font-weight:600;color:#000;margin-bottom:10px;">Banir usuário</h3>
        <%= form_with url: ban_admin_user_path(@user), method: :post, local: true, style: "display:flex;flex-direction:column;gap:8px;" do |f| %>
          <%= f.text_field :reason, placeholder: "Motivo (opcional)…", class: "form-input" %>
          <button type="submit" style="width:100%;padding:8px;border-radius:6px;background:rgba(213,20,20,0.08);color:#D51414;border:2px solid #D51414;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;">Banir</button>
        <% end %>
      <% end %>
    </div>
    <div class="card-light" style="padding:20px;">
      <h3 style="font-size:14px;font-weight:600;color:#000;margin-bottom:10px;">Apagar usuário</h3>
      <% if @projects.any? %>
        <p style="font-size:12px;color:#929292;margin-bottom:10px;">
          Usuário possui <%= @projects.count %> <%= @projects.count == 1 ? "projeto" : "projetos" %>. Apague os projetos antes de remover o usuário.
        </p>
        <button disabled style="width:100%;padding:8px;border-radius:6px;background:#f5f5f5;color:#c0c0c0;border:2px solid #e5e5e5;font-size:14px;font-weight:700;cursor:not-allowed;font-family:'Montserrat',sans-serif;">Apagar usuário</button>
      <% else %>
        <%= button_to "Apagar usuário", admin_user_path(@user), method: :delete,
            data: { confirm: "Apagar #{@user.display}? Esta ação não pode ser desfeita." },
            style: "width:100%;padding:8px;border-radius:6px;background:rgba(213,20,20,0.08);color:#D51414;border:2px solid #D51414;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;" %>
      <% end %>
    </div>
  </div>

  <%# Projects %>
  <div class="card-light" style="padding:24px;">
    <h2 style="font-size:15px;font-weight:600;color:#000;margin-bottom:16px;">Projetos (<%= @projects.count %>)</h2>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:2px solid #e5e5e5;">
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Título</th>
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Visibilidade</th>
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Destaque</th>
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Criado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |p| %>
          <tr style="border-top:1px solid #f0f0f0;">
            <td style="padding:8px 0;font-weight:600;">
              <%= link_to p.title, admin_project_path(p), style: "color:#000;text-decoration:none;" %>
            </td>
            <td style="padding:8px 0;color:#929292;font-size:12px;"><%= p.visibility %></td>
            <td style="padding:8px 0;">
              <% if p.featured %><span style="font-size:12px;color:#B87A00;font-weight:600;">★ Destaque</span><% end %>
            </td>
            <td style="padding:8px 0;color:#929292;"><%= p.created_at.strftime("%d/%m/%Y") %></td>
            <td style="padding:8px 0;text-align:right;">
              <%= link_to "Ver →", admin_project_path(p), style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:none;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
