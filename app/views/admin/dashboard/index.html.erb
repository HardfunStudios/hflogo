<% content_for :page_title, "Dashboard" %>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px;">
  <% [
    ["Usuários", @total_users, admin_users_path],
    ["Projetos", @total_projects, admin_projects_path],
    ["Publicados", @published, admin_projects_path],
    ["Destaques", @featured, admin_projects_path(featured: 1)],
  ].each do |label, count, path| %>
    <%= link_to path, class: "card-light", style: "padding:20px;text-decoration:none;display:block;transition:box-shadow .15s;" do %>
      <div style="font-size:28px;font-weight:700;color:#0081A6;"><%= count %></div>
      <div style="font-size:13px;color:#929292;margin-top:4px;"><%= label %></div>
    <% end %>
  <% end %>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
  <div class="card-light" style="padding:24px;">
    <h2 style="font-size:15px;font-weight:600;color:#000;margin-bottom:16px;">Usuários recentes</h2>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <tbody>
        <% @recent_users.each do |u| %>
          <tr style="border-top:1px solid #f0f0f0;">
            <td style="padding:8px 0;">
              <%= link_to u.display, admin_user_path(u), style: "font-weight:600;color:#000;text-decoration:none;" %>
              <span style="color:#929292;font-size:11px;margin-left:4px;">@<%= u.username %></span>
            </td>
            <td style="padding:8px 0;color:#929292;text-align:right;"><%= u.created_at.strftime("%d/%m/%Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= link_to "Ver todos →", admin_users_path, style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:none;display:inline-block;margin-top:12px;" %>
  </div>

  <div class="card-light" style="padding:24px;">
    <h2 style="font-size:15px;font-weight:600;color:#000;margin-bottom:16px;">Projetos recentes</h2>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <tbody>
        <% @recent_projects.each do |p| %>
          <tr style="border-top:1px solid #f0f0f0;">
            <td style="padding:8px 0;">
              <%= link_to p.title, admin_project_path(p), style: "font-weight:600;color:#000;text-decoration:none;" %>
              <span style="color:#929292;font-size:11px;margin-left:4px;"><%= p.visibility %></span>
            </td>
            <td style="padding:8px 0;color:#929292;text-align:right;font-size:11px;"><%= p.user.username %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= link_to "Ver todos →", admin_projects_path, style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:none;display:inline-block;margin-top:12px;" %>
  </div>
</div>
