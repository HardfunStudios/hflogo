<% content_for :page_title, "Configurações" %>

<div style="max-width:600px;">
  <%= form_with model: @setting, url: admin_settings_path, method: :patch, local: true do |f| %>

    <div class="card-light" style="padding:24px;margin-bottom:16px;">
      <h2 style="font-size:15px;font-weight:600;color:#000;margin-bottom:4px;">Google Analytics 4</h2>
      <p style="font-size:13px;color:#929292;margin-bottom:16px;">
        Informe o Measurement ID para ativar o GA4 na plataforma. Deixe em branco para desativar.
      </p>

      <div style="display:flex;flex-direction:column;gap:6px;">
        <label style="font-size:13px;font-weight:600;color:#000;">Measurement ID</label>
        <%= f.text_field :ga4_measurement_id,
            placeholder: "G-XXXXXXXXXX",
            class: "form-input",
            style: "font-family:monospace;" %>
        <p style="font-size:11px;color:#929292;">
          Encontrado em GA4 → Admin → Data Streams → seu stream → Measurement ID.
        </p>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;">
      <button type="submit" class="btn-primary" style="font-size:14px;padding:8px 24px;">Salvar</button>
      <% if @setting.ga4_measurement_id.present? %>
        <span style="font-size:13px;color:#2ECC71;font-weight:600;">
          ● GA4 ativo (<%= @setting.ga4_measurement_id %>)
        </span>
      <% else %>
        <span style="font-size:13px;color:#929292;">● GA4 inativo</span>
      <% end %>
    </div>

  <% end %>
</div>
