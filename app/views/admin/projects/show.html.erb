<% content_for :page_title, "Projeto: #{@project.title}" %>

<div style="display:grid;grid-template-columns:280px 1fr;gap:24px;align-items:start;">
  <div style="display:flex;flex-direction:column;gap:16px;">
    <div class="card-light" style="padding:24px;">
      <h2 style="font-size:17px;font-weight:700;color:#000;margin-bottom:8px;"><%= @project.title %></h2>
      <% if @project.description.present? %>
        <p style="font-size:13px;color:#929292;margin-bottom:16px;"><%= @project.description %></p>
      <% end %>
      <dl style="font-size:13px;display:flex;flex-direction:column;gap:10px;">
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Autor</dt><dd><%= link_to @project.user.display, admin_user_path(@project.user), style: "color:#0081A6;text-decoration:none;font-weight:600;" %></dd></div>
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Visibilidade</dt><dd style="color:#000;"><%= @project.visibility %></dd></div>
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Destaque</dt><dd style="color:#{@project.featured? ? '#B87A00' : '#929292'};font-weight:#{@project.featured? ? '600' : '400'};"><%= @project.featured? ? "★ Sim" : "Não" %></dd></div>
        <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Criado em</dt><dd style="color:#000;"><%= @project.created_at.strftime("%d/%m/%Y %H:%M") %></dd></div>
        <% if @project.published_at %>
          <div><dt style="font-size:11px;color:#929292;margin-bottom:2px;">Publicado em</dt><dd style="color:#000;"><%= @project.published_at.strftime("%d/%m/%Y") %></dd></div>
        <% end %>
      </dl>
    </div>

    <div class="card-light" style="padding:20px;display:flex;flex-direction:column;gap:8px;">
      <% if @project.featured? %>
        <%= button_to "Remover destaque", unfeature_admin_project_path(@project), method: :post,
            style: "width:100%;padding:8px;border-radius:6px;background:rgba(255,170,0,0.10);color:#B87A00;border:2px solid #FFAA00;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;" %>
      <% else %>
        <%= button_to "★ Marcar como destaque", feature_admin_project_path(@project), method: :post,
            style: "width:100%;padding:8px;border-radius:6px;background:rgba(0,129,166,0.08);color:#0081A6;border:2px solid #0081A6;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;" %>
      <% end %>
      <%= button_to "Excluir projeto", admin_project_path(@project), method: :delete,
          data: { turbo_confirm: "Excluir '#{@project.title}'? Esta ação não pode ser desfeita." },
          style: "width:100%;padding:8px;border-radius:6px;background:rgba(213,20,20,0.08);color:#D51414;border:2px solid #D51414;font-size:14px;font-weight:700;cursor:pointer;font-family:'Montserrat',sans-serif;" %>
    </div>
  </div>

  <div class="card-light" style="padding:24px;">
    <h3 style="font-size:15px;font-weight:600;color:#000;margin-bottom:16px;">Versões (<%= @project.versions.count %>)</h3>
    <table style="width:100%;border-collapse:collapse;font-size:13px;">
      <thead>
        <tr style="border-bottom:2px solid #e5e5e5;">
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">#</th>
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Tipo</th>
          <th style="text-align:left;padding:0 0 8px;font-size:12px;font-weight:600;color:#929292;">Data</th>
        </tr>
      </thead>
      <tbody>
        <% @project.versions.order(created_at: :desc).limit(20).each do |v| %>
          <tr style="border-top:1px solid #f0f0f0;">
            <td style="padding:7px 0;color:#929292;">v<%= v.version_number %></td>
            <td style="padding:7px 0;"><%= v.auto_save? ? "auto" : "manual" %></td>
            <td style="padding:7px 0;color:#929292;"><%= v.created_at.strftime("%d/%m/%Y %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
