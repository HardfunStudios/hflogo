<% content_for :page_title, "Projetos" %>

<div class="card-light" style="padding:24px;">
  <%= form_with url: admin_projects_path, method: :get, local: true, class: "flex gap-3 items-center mb-5" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Buscar por título…",
        class: "form-input", style: "max-width:300px;" %>
    <label style="display:flex;align-items:center;gap:6px;font-size:14px;color:#000;cursor:pointer;">
      <%= f.check_box :featured, { checked: params[:featured] == "1" }, "1", "0" %>
      Apenas destaques
    </label>
    <%= f.submit "Buscar", class: "btn-primary", style: "font-size:14px;padding:6px 16px;" %>
    <% if params[:q].present? || params[:featured] == "1" %>
      <%= link_to "Limpar", admin_projects_path, style: "font-size:14px;color:#929292;text-decoration:none;padding:6px;" %>
    <% end %>
  <% end %>

  <table style="width:100%;border-collapse:collapse;font-size:13px;">
    <thead>
      <tr style="border-bottom:2px solid #e5e5e5;">
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Título</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Autor</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Visibilidade</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Destaque</th>
        <th style="text-align:left;padding:0 0 10px;font-size:12px;font-weight:600;color:#929292;">Criado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |p| %>
        <tr style="border-top:1px solid #f0f0f0;">
          <td style="padding:10px 0;font-weight:600;">
            <%= link_to p.title, admin_project_path(p), style: "color:#000;text-decoration:none;" %>
          </td>
          <td style="padding:10px 0;color:#929292;">
            <%= link_to p.user.username, admin_user_path(p.user), style: "color:#929292;text-decoration:none;" %>
          </td>
          <td style="padding:10px 0;">
            <span style="display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;background:<%= p.published? ? 'rgba(0,129,166,0.10)' : '#f5f5f5' %>;color:<%= p.published? ? '#0081A6' : '#929292' %>;">
              <%= p.visibility %>
            </span>
          </td>
          <td style="padding:10px 0;">
            <% if p.featured %>
              <span style="color:#B87A00;font-weight:600;margin-right:6px;">★</span>
              <%= button_to "Remover", unfeature_admin_project_path(p), method: :post,
                  style: "font-size:11px;color:#929292;background:transparent;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;padding:0;text-decoration:underline;" %>
            <% else %>
              <%= button_to "Destacar", feature_admin_project_path(p), method: :post,
                  style: "font-size:12px;font-weight:700;color:#0081A6;background:transparent;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;padding:0;text-decoration:underline;" %>
            <% end %>
          </td>
          <td style="padding:10px 0;color:#929292;"><%= p.created_at.strftime("%d/%m/%Y") %></td>
          <td style="padding:10px 0;text-align:right;display:flex;gap:12px;justify-content:flex-end;">
            <%= link_to "Ver", admin_project_path(p), style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:none;" %>
            <%= button_to "Excluir", admin_project_path(p), method: :delete, data: { turbo_confirm: "Excluir '#{p.title}'? Esta ação não pode ser desfeita." },
                style: "font-size:12px;font-weight:700;color:#D51414;background:transparent;border:none;cursor:pointer;font-family:'Montserrat',sans-serif;padding:0;" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
