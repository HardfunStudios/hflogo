<% content_for :title, "Meus Projetos — Logo HardFun" %>

<div class="px-12 py-8">

  <%# Cabeçalho %>
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 style="font-size:24px;font-weight:700;color:#000;"><%= t("projects.my_projects_title") %></h1>
      <p style="font-size:14px;color:#929292;margin-top:4px;">
        <%= t("projects.count", count: @projects.count) %>
      </p>
    </div>
    <%= link_to t("projects.new_button"), new_project_path, class: "btn-primary", style: "font-size:14px;padding:8px 20px;" %>
  </div>

  <% if @projects.empty? %>
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div style="font-size:64px;margin-bottom:16px;">🐢</div>
      <h2 style="font-size:20px;font-weight:600;color:#000;margin-bottom:8px;"><%= t("projects.empty_heading") %></h2>
      <p style="font-size:15px;color:#929292;margin-bottom:24px;"><%= t("projects.empty_message") %></p>
      <%= link_to t("projects.create_button"), new_project_path, class: "btn-primary" %>
    </div>

  <% else %>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;">
      <% @projects.each do |project| %>
        <div class="card-light overflow-hidden transition-shadow duration-150 hover:shadow-md" style="padding:0;">

          <%= link_to edit_project_path(project), data: { turbo: false } do %>
            <div style="height:160px;background:#f8f9fb;display:flex;align-items:center;justify-content:center;overflow:hidden;border-bottom:1px solid #e5e5e5;">
              <% if project.thumbnail_url.present? %>
                <img src="<%= project.thumbnail_url %>" style="width:100%;height:100%;object-fit:cover;" alt="">
              <% else %>
                <span style="font-size:48px;">🐢</span>
              <% end %>
            </div>
          <% end %>

          <div style="padding:12px 14px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
              <div style="min-width:0;">
                <%= link_to edit_project_path(project),
                    style: "font-size:15px;font-weight:600;color:#000;text-decoration:none;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;",
                    data: { turbo: false } do %>
                  <%= project.title %>
                <% end %>
                <p style="font-size:12px;color:#929292;margin-top:2px;">
                  <%= t("projects.edited_ago", time: time_ago_in_words(project.updated_at)) %>
                </p>
              </div>
              <span class="<%= project.published? ? 'badge-published' : project.unlisted? ? 'badge-unlisted' : 'badge-draft' %>">
                <%= t("projects.visibility.#{project.visibility}") %>
              </span>
            </div>

            <div style="display:flex;align-items:center;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid #f0f0f0;">
              <%= link_to t("projects.edit"), edit_project_path(project),
                  style: "font-size:12px;font-weight:700;color:#0081A6;text-decoration:underline;",
                  data: { turbo: false } %>
              <%= link_to t("projects.view_link"), project_path(project),
                  style: "font-size:12px;font-weight:700;color:#929292;text-decoration:underline;" %>
              <%= button_to t("projects.delete_button"), project_path(project), method: :delete,
                  form: { data: { turbo_confirm: t("projects.delete_confirm", title: project.title) } },
                  style: "font-size:12px;font-weight:700;color:#D51414;text-decoration:underline;background:transparent;border:none;cursor:pointer;padding:0;" %>
            </div>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>
