<div class="card p-0 overflow-hidden hover:shadow-md transition-shadow">
  <%= link_to project do %>
    <div class="bg-gray-100 h-32 flex items-center justify-center">
      <% if project.thumbnail_url.present? %>
        <img src="<%= project.thumbnail_url %>" class="w-full h-full object-cover" alt="">
      <% else %>
        <span class="text-4xl">🐢</span>
      <% end %>
    </div>
    <div class="p-3">
      <p class="font-semibold text-sm truncate"><%= project.title %></p>
      <p class="text-xs text-gray-500">por <%= project.user.display %></p>
    </div>
  <% end %>
</div>
