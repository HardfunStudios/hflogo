<% content_for :title, "#{@project.title} — Logo" %>

<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
  <script src="/editor-assets/js/jquery-2.1.4.min.js"></script>
  <script src="/editor-assets/js/materialize.min.js"></script>
  <script src="/editor-assets/js/JS-Interpreter/acorn_interpreter.js"></script>
  <script src="/editor-assets/js/microworld.js"></script>
  <script src="/editor-assets/js/microworld_procedural_bindings.js"></script>
  <style>
    #show-player { display:flex; gap:16px; overflow:hidden; }
    #blocklyDiv  { flex:1; height:480px; border:1px solid #e0e0e0; border-radius:8px; overflow:hidden; background:white; }
    #stageFrame  { flex:1; height:480px; border:1px solid #e0e0e0; border-radius:8px; background:white;
                   display:flex; align-items:center; justify-content:center; overflow:hidden; }
  </style>
<% end %>

<div class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex gap-6">

    <%# Player do projeto %>
    <div class="flex-1 flex flex-col gap-3">

      <%# Blocos + Canvas lado a lado %>
      <div id="show-player">
        <div id="blocklyDiv"></div>
        <div id="stageFrame"></div>
      </div>

      <%# Controles %>
      <div class="flex items-center gap-3">
        <button id="runButton" class="btn-primary" style="font-size:14px;padding:6px 18px;">▶ Executar</button>
        <button id="stepButton" class="btn-secondary" style="font-size:14px;padding:6px 14px;">→ Passo</button>
        <label style="font-size:13px;color:#929292;display:flex;align-items:center;gap:6px;">
          <input type="checkbox" id="isTimeVisible"> Mostra passos
        </label>
      </div>
      <div>
        <input type="range" id="programTimeSlider" class="w-full" min="1" max="1" value="1">
      </div>

    </div>

    <%# Sidebar do projeto %>
    <div class="w-72 flex-shrink-0 space-y-4">
      <div class="card">
        <h1 class="text-xl font-bold mb-1"><%= @project.title %></h1>
        <p class="text-sm text-gray-500 mb-3">
          por <%= link_to @project.user.display, user_profile_path(@project.user.username), class: "text-hf-blue hover:underline" %>
          · <%= l(@project.published_at, format: :short) if @project.published_at %>
        </p>

        <% if @project.description.present? %>
          <p class="text-sm text-gray-700 mb-4"><%= simple_format(@project.description) %></p>
        <% end %>

        <div class="flex gap-3 text-sm text-gray-500">
          <span>👁 <%= @project.views_count %></span>
          <span>❤️ <%= @project.loves_count %></span>
          <span>🔀 <%= @project.remixes_count %></span>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <% if user_signed_in? && current_user != @project.user %>
          <%= button_to t("projects.remix"), remix_project_path(@project), method: :post,
              class: "btn-secondary text-sm px-4 py-2 w-full" %>
        <% end %>

        <% if user_signed_in? && current_user == @project.user %>
          <%= link_to t("projects.edit"), edit_project_path(@project),
              class: "btn-primary text-sm px-4 py-2 w-full text-center",
              data: { turbo: false } %>
        <% end %>
      </div>

      <% if @project.parent_project %>
        <div class="card text-sm">
          <p class="font-semibold mb-1">Remix de</p>
          <%= link_to @project.parent_project.title, @project.parent_project,
              class: "text-hf-blue hover:underline" %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<script>window._logoEditorReadOnly = true;</script>
<script src="<%= asset_path('logo-editor.js') %>"></script>
<script>
  (function() {
    const data = <%= raw @project.data.to_json %>;
    function loadProject() { window.LogoEditor.loadProjectState(data); }
    if (window._logoEditorInitialized) {
      loadProject();
    } else {
      window._logoEditorReadyCallback = loadProject;
    }
  })();
</script>
