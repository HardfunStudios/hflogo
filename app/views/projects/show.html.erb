<% content_for :title, "#{@project.title} — Logo" %>
<% content_for :main_style, "display:flex;flex-direction:column;min-height:0;overflow:hidden;" %>

<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
  <script src="/editor-assets/js/jquery-2.1.4.min.js"></script>
  <script src="/editor-assets/js/materialize.min.js"></script>
  <script src="/editor-assets/js/JS-Interpreter/acorn_interpreter.js"></script>
  <script src="/editor-assets/js/microworld.js"></script>
  <script src="/editor-assets/js/microworld_procedural_bindings.js"></script>
  <style>
    #show-root { display:flex; flex-direction:column; flex:1; overflow:hidden; min-height:0; background:#f5f5f5; }

    #show-header {
      display:flex; align-items:center; gap:12px; flex-shrink:0;
      height:52px; padding:0 16px; background:white;
      box-shadow:0 2px 4px 0 rgba(0,0,0,0.12); z-index:10;
    }
    #show-header h1 {
      flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
      font-size:15px; font-weight:600; font-family:'Montserrat',sans-serif; color:black;
    }

    #show-main { display:flex; flex:1; overflow:hidden; min-height:0; }

    #show-editor { display:flex; flex:1; overflow:hidden; min-height:0; min-width:0; }

    #blocklyDiv {
      flex:1; min-width:0; position:relative; overflow:hidden; background:white;
      border-right:1px solid #e0e0e0;
    }
    #blocklyDiv > svg { display:block; }

    #blockly-zoom {
      position:absolute; bottom:12px; right:12px; z-index:10;
      display:flex; flex-direction:column; gap:4px;
    }
    #blockly-zoom button {
      width:30px; height:30px; border-radius:6px;
      border:1.5px solid #d0d0d0; background:white;
      font-size:16px; line-height:1; cursor:pointer; color:#444;
      display:flex; align-items:center; justify-content:center;
      box-shadow:0 1px 4px rgba(0,0,0,0.10);
      transition:background 100ms;
    }
    #blockly-zoom button:hover { background:#f0f0f0; }

    #stagePanel {
      flex:1; min-width:0; display:flex; flex-direction:column;
      background:#f5f5f5; overflow:hidden;
    }

    #stageFrame {
      flex:1; display:flex; align-items:center; justify-content:center;
      background:#f5f5f5; overflow:hidden; padding:16px;
    }
    #stageFrame canvas {
      display:block;
      border:2px solid #e0e0e0;
      border-radius:8px;
      box-shadow:0 2px 8px rgba(0,0,0,0.10);
      background:white;
    }

    #stageToolbar {
      display:flex; align-items:center; gap:8px;
      padding:10px 14px; background:white;
      border-top:1px solid #e8e8e8; flex-shrink:0;
    }

    #runButton, #stopButton, #stepButton {
      display:flex; align-items:center; justify-content:center;
      width:38px; height:38px; border-radius:50%;
      cursor:pointer; font-size:15px; color:white; flex-shrink:0;
      transition:background 120ms;
    }
    #runButton { background:#3dba4e; border:3px solid #2fa040; }
    #runButton:hover:not(:disabled) { background:#35a844; }
    #stopButton { background:#D51414; border:3px solid #b01010; }
    #stopButton:hover { background:#b01010; }
    #speedSlider { width:72px; accent-color:#0081A6; cursor:pointer; vertical-align:middle; margin:0 2px; }
    .speed-wrap { display:flex; align-items:center; gap:3px; }
    #stepButton { background:#0081A6; border:3px solid #006e8e; }
    #stepButton:hover:not(:disabled) { background:#006e8e; }

    #runButton.running { background:#e8a000; border-color:#c88800; cursor:not-allowed; }
    #runButton.running::after {
      content:''; display:block;
      width:16px; height:16px; border-radius:50%;
      border:3px solid rgba(255,255,255,0.3);
      border-top-color:white;
      animation:spin 0.7s linear infinite;
    }
    #runButton.running span { display:none; }
    @keyframes spin { to { transform:rotate(360deg); } }

    #stageToolbar label {
      display:flex; align-items:center; gap:5px;
      font-size:12px; color:#929292; cursor:pointer;
      font-family:'Montserrat',sans-serif;
    }

    #sliderArea { padding:6px 14px 10px; background:white; flex-shrink:0; border-top:1px solid #f0f0f0; }
    #programTimeSlider { width:100%; accent-color:#0081A6; cursor:pointer; }
    #sliderArea output, #sliderArea span { display:none !important; }
    #stepsText { font-size:11px; color:#929292; font-family:'Montserrat',sans-serif; }

    #show-sidebar {
      width:280px; flex-shrink:0; overflow-y:auto;
      background:white; border-left:1px solid #e0e0e0;
      padding:20px 16px; display:flex; flex-direction:column; gap:16px;
    }
    #show-sidebar .project-title {
      font-size:16px; font-weight:700; font-family:'Montserrat',sans-serif; color:black;
    }
    #show-sidebar .project-meta {
      font-size:12px; color:#929292; margin-top:4px;
    }
    #show-sidebar .project-desc {
      font-size:13px; color:#444; line-height:1.5;
    }
    #show-sidebar .project-stats {
      display:flex; gap:12px; font-size:12px; color:#929292;
    }
    #show-sidebar .divider {
      border:none; border-top:1px solid #f0f0f0; margin:0;
    }
  </style>
<% end %>

<div id="show-root">

  <%# ── Header ── %>
  <div id="show-header">
    <%= link_to root_path do %>
      <div class="relative flex-shrink-0" style="width:26px;height:22px;">
        <img src="/images/logo-part-4.svg" alt="" class="absolute" style="left:.5px;top:0;width:25px;height:10.7px;">
        <img src="/images/table-header-bg.svg" alt="" class="absolute" style="left:0;top:5.7px;width:12.7px;height:16px;">
        <img src="/images/table-header-mask.svg" alt="" class="absolute" style="left:13.2px;top:5.7px;width:12.7px;height:16px;">
      </div>
    <% end %>

    <h1><%= @project.title %></h1>

    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0;">
      <% if user_signed_in? && current_user == @project.user %>
        <%= link_to t("projects.edit"), edit_project_path(@project),
            class: "btn-secondary", style: "font-size:12px;padding:4px 12px;",
            data: { turbo: false } %>
      <% end %>
      <% if user_signed_in? && current_user != @project.user %>
        <%= button_to t("projects.remix"), remix_project_path(@project), method: :post,
            class: "btn-secondary", style: "font-size:12px;padding:4px 12px;" %>
      <% end %>
    </div>
  </div>

  <%# ── Main ── %>
  <div id="show-main">

    <div id="show-editor">
      <div id="blocklyDiv">
        <div id="blockly-zoom">
          <button id="zoomInBtn"  title="Zoom in">+</button>
          <button id="zoomOutBtn" title="Zoom out">−</button>
          <button id="zoomFitBtn" title="Ajustar à tela" style="font-size:12px;">⊡</button>
        </div>
      </div>

      <div id="stagePanel">
        <div id="stageFrame"></div>

        <div id="stageToolbar">
          <button id="runButton" title="Executar (F5)"><span>▶</span></button>
          <button id="stopButton" title="Parar execução">■</button>
          <button id="stepButton" title="Passo">→</button>
          <span class="speed-wrap">
            <span style="font-size:13px;">🐢</span>
            <input type="range" id="speedSlider" min="1" max="5" step="1" value="5" title="Velocidade de execução">
            <span style="font-size:13px;">🐇</span>
          </span>
          <label style="margin-left:8px;">
            <input type="checkbox" id="isTimeVisible" style="accent-color:#0081A6;">
            Mostra passos
          </label>
        </div>

        <div id="sliderArea">
          <input type="range" id="programTimeSlider" min="1" max="1" value="1">
          <div id="stepsText"></div>
        </div>
      </div>
    </div>

    <%# ── Sidebar ── %>
    <div id="show-sidebar">
      <div>
        <div class="project-title"><%= @project.title %></div>
        <div class="project-meta">
          por <%= link_to @project.user.display, user_profile_path(@project.user.username),
                  style: "color:#0081A6;" %>
          <% if @project.published_at %>
            · <%= l(@project.published_at, format: :short) %>
          <% end %>
        </div>
      </div>

      <% if @project.description.present? %>
        <hr class="divider">
        <div class="project-desc"><%= simple_format(@project.description) %></div>
      <% end %>

      <hr class="divider">
      <div class="project-stats">
        <span>👁 <%= @project.views_count %></span>
        <span>❤️ <%= @project.loves_count %></span>
        <span>🔀 <%= @project.remixes_count %></span>
      </div>

      <% if @project.parent_project %>
        <hr class="divider">
        <div style="font-size:12px;color:#929292;">
          Remix de <%= link_to @project.parent_project.title, @project.parent_project,
                          style: "color:#0081A6;" %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<script>window._logoEditorReadOnly = true;</script>
<script src="<%= asset_path('logo-editor.js') %>"></script>
<script>
(function() {
  const data = <%= raw @project.data.to_json %>;
  function loadProject() { window.LogoEditor.loadProjectState(data); }
  if (window._logoEditorInitialized) {
    loadProject();
  } else {
    window._logoEditorReadyCallback = loadProject;
  }

  document.getElementById('zoomInBtn').addEventListener('click', function() {
    window.workspace.zoomCenter(1);
  });
  document.getElementById('zoomOutBtn').addEventListener('click', function() {
    window.workspace.zoomCenter(-1);
  });
  document.getElementById('zoomFitBtn').addEventListener('click', function() {
    window.workspace.zoomToFit();
  });

  // Prevent Materialize from hijacking the speed slider
  var speedSlider = document.getElementById('speedSlider');
  if (speedSlider) {
    ['mousedown','mouseup','input','change'].forEach(function(ev) {
      speedSlider.addEventListener(ev, function(e) { e.stopPropagation(); }, true);
    });
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'F5') { e.preventDefault(); document.getElementById('runButton').click(); }
  });
})();
</script>
