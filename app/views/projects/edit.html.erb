<% content_for :title, "#{@project.title} — Logo" %>
<% content_for :main_style, "display:flex;flex-direction:column;min-height:0;overflow:hidden;" %>

<% content_for :head do %>
  <script src="/editor-assets/js/jquery-2.1.4.min.js"></script>
  <script src="/editor-assets/js/materialize.min.js"></script>
  <script src="/editor-assets/js/JS-Interpreter/acorn_interpreter.js"></script>
  <script src="/editor-assets/js/microworld.js"></script>
  <script src="/editor-assets/js/microworld_procedural_bindings.js"></script>
  <style>
    /* ── Root ───────────────────────────────────────────────────────── */
    #editor-root {
      display:flex; flex-direction:column; flex:1;
      overflow:hidden; min-height:0; background:#f0f0f0;
    }

    /* ── Header ─────────────────────────────────────────────────────── */
    #editor-header {
      display:flex; align-items:center; gap:12px; flex-shrink:0;
      height:52px; padding:0 16px; background:white;
      box-shadow:0 2px 4px 0 rgba(0,0,0,0.12); z-index:10;
    }
    #editor-header input[type="text"] {
      flex:1; min-width:0; border:none; outline:none;
      font-size:15px; font-weight:600; font-family:'Montserrat',sans-serif;
      color:black; background:transparent; padding:4px 8px; border-radius:4px;
    }
    #editor-header input[type="text"]:hover { background:#f5f5f5; }
    #editor-header input[type="text"]:focus { background:#f0f7fb; }

    /* ── Main area ──────────────────────────────────────────────────── */
    #editor-main {
      display:flex; flex:1; overflow:hidden; min-height:0;
      gap:12px; padding:12px;
    }

    /* ── Card shared ────────────────────────────────────────────────── */
    .editor-card {
      display:flex; flex-direction:column; overflow:hidden; min-height:0;
      border:1px solid #929292; border-radius:12px;
      box-shadow:0 2px 4px 1px rgba(0,0,0,0.15);
      background:white;
    }

    /* ═══════════════════════════════════════════════════════════════
       PAINEL ESQUERDO — editor com abas estilo browser
    ═══════════════════════════════════════════════════════════════ */
    #leftPanel { flex:1; min-width:0; }

    /* Barra de abas */
    #editorTabBar {
      display:flex; align-items:flex-end; flex-shrink:0;
      background:#e8e8e8; padding:8px 12px 0; gap:4px;
      border-radius:12px 12px 0 0;
    }

    .editor-tab {
      display:flex; align-items:center; gap:7px;
      padding:7px 16px 8px;
      font-size:13px; font-weight:600; font-family:'Montserrat',sans-serif;
      border:1px solid #c0c0c0; border-bottom:none; border-radius:6px 6px 0 0;
      background:#d4d4d4; color:#777;
      cursor:pointer; white-space:nowrap;
      transition:background 120ms, color 120ms;
      position:relative; bottom:-1px;
    }
    .editor-tab.active {
      background:white; color:#0081A6;
      border-color:#929292;
      z-index:1;
    }
    .editor-tab:hover:not(.active) { background:#c8c8c8; color:#444; }

    .editor-tab svg { flex-shrink:0; }

    /* Linha separadora entre abas e conteúdo */
    #editorTabContent {
      flex:1; min-height:0; display:flex; flex-direction:column; overflow:hidden;
      border-top:1px solid #929292;
    }

    /* Blockly */
    #blocklyDiv {
      flex:1; min-width:0; position:relative; overflow:hidden; background:white;
    }
    #blocklyDiv > svg { display:block; }
    .blocklyFlyout ~ .blocklyScrollbarVertical,
    .blocklyFlyoutScrollbar,
    g.blocklyScrollbar[display="none"],
    .blocklyFlyout + .blocklyScrollbar { display:none !important; }

    /* Painel de texto Logo */
    #logoTextPanel {
      flex:1; display:none; flex-direction:column; overflow:hidden;
      background:#1e1e1e;
    }
    #logoTextPanel.active { display:flex; }
    #logoTextToolbar {
      display:flex; align-items:center; gap:8px;
      padding:6px 12px; background:#2d2d2d; flex-shrink:0;
      border-bottom:1px solid #444;
    }
    #logoTextToolbar span {
      font-size:11px; font-family:'Montserrat',sans-serif; color:#929292;
    }
    #logoCodeEditor {
      flex:1; width:100%; border:none; outline:none; resize:none;
      background:#1e1e1e; color:#d4d4d4;
      font-family:'Fira Code','Cascadia Code','Menlo','Consolas',monospace;
      font-size:13px; line-height:1.6; padding:16px;
      tab-size:2; white-space:pre; overflow:auto;
    }

    /* ═══════════════════════════════════════════════════════════════
       PAINEL DIREITO — micromundo estilo tabela
    ═══════════════════════════════════════════════════════════════ */
    #stagePanel { width:420px; flex-shrink:0; }

    /* Header gradiente — igual ao cabeçalho da tabela */
    #stageHeader {
      display:flex; align-items:center; gap:8px; flex-shrink:0;
      padding:10px 14px;
      background:linear-gradient(to right, #0081A6, #00A8C0);
      border-radius:12px 12px 0 0;
    }

    #runButton, #stopButton, #stepButton {
      display:flex; align-items:center; justify-content:center;
      width:34px; height:34px; border-radius:50%;
      cursor:pointer; font-size:14px; color:white; flex-shrink:0;
      transition:background 120ms;
    }
    #runButton  { background:rgba(255,255,255,0.20); border:2px solid rgba(255,255,255,0.50); }
    #runButton:hover:not(:disabled) { background:rgba(255,255,255,0.32); }
    #stopButton { background:rgba(213,20,20,0.75);   border:2px solid rgba(213,20,20,0.90); }
    #stopButton:hover { background:rgba(176,16,16,0.90); }
    #stepButton { background:rgba(255,255,255,0.15); border:2px solid rgba(255,255,255,0.40); }
    #stepButton:hover:not(:disabled) { background:rgba(255,255,255,0.28); }

    #runButton.running { background:rgba(232,160,0,0.80); border-color:rgba(200,136,0,0.90); cursor:not-allowed; }
    #runButton.running::after {
      content:''; display:block;
      width:14px; height:14px; border-radius:50%;
      border:2px solid rgba(255,255,255,0.3); border-top-color:white;
      animation:spin 0.7s linear infinite;
    }
    #runButton.running span { display:none; }
    @keyframes spin { to { transform:rotate(360deg); } }

    #speedSlider { width:64px; accent-color:white; cursor:pointer; vertical-align:middle; }
    .speed-wrap { display:flex; align-items:center; gap:3px; }

    #stageHeader label {
      display:flex; align-items:center; gap:5px;
      font-size:12px; color:rgba(255,255,255,0.85);
      font-family:'Montserrat',sans-serif; cursor:pointer;
    }
    #stageHeader label input[type="checkbox"] { accent-color:white; }

    /* Canvas area */
    #stageFrame {
      flex:1; display:flex; align-items:center; justify-content:center;
      background:#f5f5f5; overflow:hidden; padding:12px;
    }
    #stageFrame canvas {
      display:block;
      border:1px solid #e0e0e0; border-radius:6px;
      box-shadow:0 2px 6px rgba(0,0,0,0.10);
      background:white;
    }

    /* Slider area */
    #sliderArea {
      padding:6px 14px 8px; background:white; flex-shrink:0;
      border-top:1px solid #e8e8e8;
      border-radius:0 0 12px 12px;
    }
    #programTimeSlider { width:100%; accent-color:#0081A6; cursor:pointer; }
    #sliderArea output, #sliderArea span { display:none !important; }
    #stepsText { font-size:11px; color:#929292; font-family:'Montserrat',sans-serif; }

    /* Misc */
    select.vis-select {
      height:30px; border:1.5px solid #d0d0d0; border-radius:6px;
      font-size:12px; padding:0 8px; background:white;
      font-family:'Montserrat',sans-serif; cursor:pointer; color:black;
    }
  </style>
<% end %>

<div id="editor-root"
     data-controller="editor"
     data-editor-project-id-value="<%= @project.id %>"
     data-editor-project-data-value="<%= html_escape(@project.data.is_a?(String) ? @project.data : @project.data.to_json) %>"
     data-editor-autosave-url-value="<%= api_v1_project_path(@project) %>"
     data-editor-versions-url-value="<%= api_v1_project_versions_path(@project) %>"
     data-editor-thumbnail-url-value="<%= thumbnail_api_v1_project_path(@project) %>"
     data-editor-csrf-token-value="<%= form_authenticity_token %>">

  <%# ── Header ── %>
  <div id="editor-header">
    <%= link_to root_path do %>
      <div class="relative flex-shrink-0" style="width:26px;height:22px;">
        <img src="/images/logo-part-4.svg" alt="" class="absolute" style="left:.5px;top:0;width:25px;height:10.7px;">
        <img src="/images/table-header-bg.svg" alt="" class="absolute" style="left:0;top:5.7px;width:12.7px;height:16px;">
        <img src="/images/table-header-mask.svg" alt="" class="absolute" style="left:13.2px;top:5.7px;width:12.7px;height:16px;">
      </div>
    <% end %>

    <input type="text"
           value="<%= @project.title %>"
           data-editor-target="titleInput"
           data-action="blur->editor#updateTitle change->editor#updateTitle">

    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;flex-shrink:0;">
      <span style="font-size:11px;color:#929292;" data-editor-target="saveStatus"><%= t("projects.auto_saved") %></span>

      <select class="vis-select" data-action="change->editor#changeVisibility">
        <option value="draft"     <%= "selected" if @project.draft? %>><%= t("projects.visibility.draft") %></option>
        <option value="unlisted"  <%= "selected" if @project.unlisted? %>><%= t("projects.visibility.unlisted") %></option>
        <option value="published" <%= "selected" if @project.published? %>><%= t("projects.visibility.published") %></option>
      </select>

      <button class="btn-secondary" style="font-size:12px;padding:4px 12px;"
              data-action="editor#saveVersion" data-editor-target="saveVersionBtn">
        Salvar versão
      </button>

      <button class="btn-primary" style="font-size:12px;padding:4px 14px;"
              data-action="editor#publish" data-editor-target="publishBtn">
        <%= @project.published_at ? t("projects.republish") : t("projects.publish") %>
      </button>
    </div>
  </div>

  <%# ── Main ── %>
  <div id="editor-main">

    <%# ── Card esquerdo: editor com abas ── %>
    <div id="leftPanel" class="editor-card">

      <%# Barra de abas estilo browser %>
      <div id="editorTabBar">
        <button class="editor-tab active" id="tabBlocos" aria-selected="true">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="currentColor"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="currentColor"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="currentColor"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="currentColor"/>
          </svg>
          Blocos
        </button>
        <button class="editor-tab" id="tabLogo" aria-selected="false">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 4l4 3-4 3M8 10h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Logo
        </button>
      </div>

      <%# Conteúdo das abas %>
      <div id="editorTabContent">

        <%# Workspace Blockly %>
        <div id="blocklyDiv"></div>

        <%# Painel de texto Logo (oculto por enquanto) %>
        <div id="logoTextPanel">
          <div id="logoTextToolbar">
            <span>Edição em texto — Logo</span>
          </div>
          <textarea id="logoCodeEditor" spellcheck="false" autocomplete="off"
                    placeholder="; código Logo aparecerá aqui"></textarea>
        </div>

      </div>
    </div>

    <%# ── Card direito: micromundo ── %>
    <div id="stagePanel" class="editor-card">

      <%# Header gradiente — estilo cabeçalho de tabela %>
      <div id="stageHeader">
        <button id="runButton" title="Executar (F5)"><span>▶</span></button>
        <button id="stopButton" title="Parar execução">■</button>
        <button id="stepButton" title="Passo">→</button>
        <span class="speed-wrap">
          <span style="font-size:13px;opacity:.7;">🐢</span>
          <input type="range" id="speedSlider" min="1" max="5" step="1" value="5" title="Velocidade">
          <span style="font-size:13px;opacity:.7;">🐇</span>
        </span>
        <label style="margin-left:4px;">
          <input type="checkbox" id="isTimeVisible">
          Mostra passos
        </label>
      </div>

      <%# Canvas %>
      <div id="stageFrame"></div>

      <%# Slider de tempo %>
      <div id="sliderArea">
        <input type="range" id="programTimeSlider" min="1" max="1" value="1">
        <div id="stepsText"></div>
      </div>

    </div>

  </div>
</div>

<script src="<%= asset_path('logo-editor.js') %>"></script>
<script>
(function () {
  const blocklyDiv = document.getElementById('blocklyDiv');
  if (window.ResizeObserver) {
    new ResizeObserver(function () {
      if (window.workspace) window.workspace.resize();
    }).observe(blocklyDiv);
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'F5') { e.preventDefault(); document.getElementById('runButton').click(); }
  });
  var speedSlider = document.getElementById('speedSlider');
  if (speedSlider) {
    ['mousedown','mouseup','input','change'].forEach(function(ev) {
      speedSlider.addEventListener(ev, function(e) { e.stopPropagation(); }, true);
    });
  }
})();
</script>
