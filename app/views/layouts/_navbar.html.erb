<nav class="bg-white shadow-sm border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      <div class="flex items-center gap-6">
        <%= link_to t("app.name"), root_path, class: "text-xl font-bold text-hf-blue" %>
        <%= link_to t("nav.explore"), explore_path, class: "text-gray-600 hover:text-hf-blue transition-colors" %>
      </div>

      <div class="flex items-center gap-4">
        <% if user_signed_in? %>
          <%= link_to t("nav.new_project"), new_project_path,
              class: "btn-primary text-sm px-4 py-2" %>
          <%= link_to t("nav.feed"), feed_path,
              class: "text-gray-600 hover:text-hf-blue transition-colors" %>
          <div class="relative group">
            <button class="flex items-center gap-2 text-gray-700 hover:text-hf-blue">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" class="w-8 h-8 rounded-full" alt="">
              <% else %>
                <div class="w-8 h-8 rounded-full bg-hf-blue text-white flex items-center justify-center text-sm font-bold">
                  <%= current_user.display.first.upcase %>
                </div>
              <% end %>
              <span class="text-sm"><%= current_user.display %></span>
            </button>
            <div class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 hidden group-hover:block z-10 border">
              <%= link_to t("nav.profile"), user_profile_path(current_user.username),
                  class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
              <%= link_to t("nav.settings"), edit_user_registration_path,
                  class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
              <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
                  class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            </div>
          </div>
        <% else %>
          <%= link_to t("nav.sign_in"), new_user_session_path,
              class: "text-gray-600 hover:text-hf-blue transition-colors" %>
          <%= link_to t("nav.sign_up"), new_user_registration_path,
              class: "btn-primary text-sm px-4 py-2" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
