<header class="fixed top-0 left-0 w-full bg-white z-50" style="height:72px;box-shadow:0 4px 4px 0 rgba(0,0,0,0.25);">
  <div class="flex items-center h-full px-10 gap-12">

    <%# Logo %>
    <%= link_to root_path, class: "flex items-center gap-2 flex-shrink-0" do %>
      <div class="relative flex-shrink-0" style="width:36px;height:31px;">
        <img src="/images/logo-part-4.svg" alt="" class="absolute" style="left:.7px;top:0;width:34.8px;height:14.9px;">
        <img src="/images/table-header-bg.svg" alt="" class="absolute" style="left:0;top:8px;width:17.7px;height:22.3px;">
        <img src="/images/table-header-mask.svg" alt="" class="absolute" style="left:18.4px;top:8px;width:17.7px;height:22.3px;">
      </div>
      <img src="/images/logo-cube.svg" alt="HardFun Logo" style="width:90px;height:16px;">
    <% end %>

    <%# Nav %>
    <nav class="flex items-center" style="gap:40px;">
      <%= link_to t("nav.explore"), explore_path,
          class: "text-black hover:opacity-70 transition-opacity",
          style: "font-size:18px;font-weight:400;" %>
      <% if user_signed_in? %>
        <%= link_to t("nav.feed"), feed_path,
            class: "text-black hover:opacity-70 transition-opacity",
            style: "font-size:18px;font-weight:400;" %>
      <% end %>
    </nav>

    <%# Direita %>
    <div class="flex items-center gap-4 ml-auto">
      <% if user_signed_in? %>
        <%= link_to t("nav.new_project"), new_project_path,
            class: "btn-primary", style: "font-size:14px;padding:7px 16px;" %>
        <div class="relative group">
          <button class="flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity">
            <% if current_user.avatar_url.present? %>
              <img src="<%= current_user.avatar_url %>" class="rounded-full" style="width:40px;height:40px;object-fit:cover;" alt="">
            <% else %>
              <div class="rounded-full flex items-center justify-center text-white font-bold text-sm"
                   style="width:40px;height:40px;background:#0081A6;">
                <%= current_user.display.first.upcase %>
              </div>
            <% end %>
            <span style="font-size:16px;font-weight:400;color:black;"><%= current_user.display %></span>
          </button>
          <div class="absolute right-0 bg-white rounded-xl py-2 hidden group-hover:block"
               style="top:calc(100% + 8px);min-width:180px;box-shadow:1px 1px 6px 0 rgba(0,0,0,0.25);border:1px solid #e5e5e5;">
            <%= link_to t("nav.profile"), user_profile_path(current_user.username),
                class: "block px-4 py-2 text-black hover:bg-gray-50 transition-colors",
                style: "font-size:15px;" %>
            <%= link_to t("nav.settings"), edit_user_registration_path,
                class: "block px-4 py-2 text-black hover:bg-gray-50 transition-colors",
                style: "font-size:15px;" %>
            <div class="border-t border-gray-100 my-1"></div>
            <%= button_to t("nav.sign_out"), destroy_user_session_path, method: :delete,
                class: "block w-full text-left px-4 py-2 hover:bg-gray-50 transition-colors",
                style: "font-size:15px;color:#D51414;background:transparent;border:none;cursor:pointer;" %>
          </div>
        </div>
      <% else %>
        <%= link_to t("nav.sign_in"), new_user_session_path,
            class: "text-black hover:opacity-70 transition-opacity",
            style: "font-size:16px;font-weight:400;" %>
        <%= link_to t("nav.sign_up"), new_user_registration_path,
            class: "btn-primary", style: "font-size:14px;padding:7px 16px;" %>
      <% end %>
    </div>

  </div>
</header>
<div style="height:72px;flex-shrink:0;"></div>
