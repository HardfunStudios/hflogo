<style>
  #about-root { display:flex; min-height:calc(100vh - 104px); }

  #about-sidebar {
    width:240px; flex-shrink:0;
    background:white; border-right:1px solid #e5e5e5;
    padding:32px 0; position:sticky; top:104px; height:calc(100vh - 104px); overflow-y:auto;
  }
  #about-sidebar h2 {
    font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
    color:#929292; padding:0 24px; margin-bottom:12px;
  }
  #about-sidebar nav { display:flex; flex-direction:column; }
  #about-sidebar a {
    display:block; padding:9px 24px;
    font-size:14px; color:#333; text-decoration:none;
    border-left:3px solid transparent;
    transition:background .12s, color .12s;
  }
  #about-sidebar a:hover { background:#f8f9fb; color:#0081A6; }
  #about-sidebar a.active {
    color:#0081A6; font-weight:600;
    border-left-color:#0081A6; background:rgba(0,129,166,0.06);
  }

  #about-content {
    flex:1; padding:48px 64px; max-width:860px;
  }
  #about-content h1 { font-size:30px; font-weight:700; color:#000; margin-bottom:8px; }
  #about-content .page-meta { font-size:13px; color:#929292; margin-bottom:32px; }
  #about-content .prose { font-size:15px; line-height:1.75; color:#222; }
  #about-content .prose h1 { font-size:22px; font-weight:700; margin:40px 0 12px; color:#000; }
  #about-content .prose h2 { font-size:18px; font-weight:700; margin:32px 0 12px; color:#000; }
  #about-content .prose h3 { font-size:15px; font-weight:700; margin:24px 0 8px; color:#000; }
  #about-content .prose p { margin:0 0 16px; }
  #about-content .prose ul, #about-content .prose ol { margin:0 0 16px; padding-left:24px; }
  #about-content .prose li { margin-bottom:6px; }
  #about-content .prose blockquote {
    border-left:3px solid #0081A6; margin:24px 0;
    padding:12px 20px; background:#f0f8fb; color:#333; font-style:italic;
    border-radius:0 6px 6px 0;
  }
  #about-content .prose pre {
    background:#1e1e2e; color:#cdd6f4; border-radius:0 0 8px 8px;
    padding:16px 20px; font-size:13px; overflow-x:auto; margin:0;
    font-family:'Roboto Mono', 'Courier New', monospace;
  }
  .logo-code-block { border:1px solid #e0e0e0; border-radius:8px; overflow:hidden; margin:0 0 16px; }
  .logo-code-block-header { display:flex; align-items:center; justify-content:space-between; padding:7px 14px; background:#f8f9fb; border-bottom:1px solid #e0e0e0; }
  .logo-code-block-header span { font-size:11px; font-weight:700; color:#929292; letter-spacing:.06em; }
  .logo-code-block-toggle { font-size:12px; padding:3px 10px; border-radius:4px; border:1px solid #0081A6; background:#0081A6; color:white; cursor:pointer; line-height:1.6; }
  .logo-code-block-toggle.blocks-active { background:white; color:#0081A6; }
  .logo-code-block-blocks { display:none; height:380px; background:#f8f9fb; }
  /* Logo syntax highlight colours */
  .lh-kw  { color:#89b4fa; }
  .lh-cmd { color:#a6e3a1; }
  .lh-num { color:#fab387; }
  .lh-str { color:#f9e2af; }
  .lh-var { color:#cba6f7; }
  .lh-cmt { color:#585b70; font-style:italic; }
  #about-content .prose code {
    background:#f0f0f0; color:#d63384; padding:2px 6px; border-radius:4px;
    font-size:13px; font-family:'Roboto Mono', 'Courier New', monospace;
  }
  #about-content .prose pre code { background:none; color:inherit; padding:0; border-radius:0; }
  #about-content .prose hr { border:none; border-top:1px solid #e5e5e5; margin:32px 0; }
  #about-content .prose table { border-collapse:collapse; width:100%; margin:0 0 16px; }
  #about-content .prose th { background:#f8f9fb; font-weight:600; }
  #about-content .prose th, #about-content .prose td {
    border:1px solid #e5e5e5; padding:8px 14px; font-size:14px; text-align:left;
  }

  .page-nav { display:flex; justify-content:space-between; margin-top:48px; padding-top:24px; border-top:1px solid #e5e5e5; }
  .page-nav a { font-size:14px; color:#0081A6; text-decoration:none; }
  .page-nav a:hover { text-decoration:underline; }
</style>

<div id="about-root">

  <aside id="about-sidebar">
    <h2>Documentação</h2>
    <nav>
      <% @pages.each do |p| %>
        <%= link_to p.nav_label, about_page_path(p.slug), class: (p.slug == @page.slug ? "active" : "") %>
      <% end %>
    </nav>
  </aside>

  <div id="about-content">
    <h1><%= @page.title %></h1>

    <div class="prose">
      <%= raw @page.content %>
    </div>

    <% current_index = @pages.index(@page) %>
    <div class="page-nav">
      <div>
        <% if current_index > 0 %>
          <%= link_to "← #{@pages[current_index - 1].nav_label}", about_page_path(@pages[current_index - 1].slug) %>
        <% end %>
      </div>
      <div>
        <% if current_index < @pages.length - 1 %>
          <%= link_to "#{@pages[current_index + 1].nav_label} →", about_page_path(@pages[current_index + 1].slug) %>
        <% end %>
      </div>
    </div>
  </div>

</div>

<script>
(function() {
  // ── Logo syntax highlighter ───────────────────────────────────────────────
  function highlightLogo(code) {
    var KW  = /\b(aprenda|fim|se|então|senão|enquanto|repita|para|faça|retorna|pare|comece|termine)\b/gi;
    var CMD = /\b(parafrente|pf|paratras|pt|viradireita|vd|viraesquerda|ve|vaipara|mudadirecao|casa|mostra|esconde|arco|aponta|mudacor|mudatamanho|mudatom|levantacaneta|abaixacaneta|preenche|limpa|limpatela|wrap|fence|window|tamanhocaneta|corcaneta|tomcaneta|distancia|direcao_ate|int|arredonda|arcoseno|arcocosseno|arcotangente|soma|produto|resto|potencia|diferenca|maximo|minimo|aleatorio|escreva|mostre)\b/gi;
    var NUM = /\b\d+(\.\d+)?\b/g;
    var VAR = /:[A-Za-zÀ-ÿ_]\w*/g;
    var CMT = /;[^\n]*/g;
    var STR = /"[^\s]*/g;
    var spans = [];
    var out = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    function mark(re, cls) {
      out = out.replace(re, function(m) {
        var i = spans.length;
        spans.push('<span class="' + cls + '">' + m + '</span>');
        return '\x00' + i + '\x00';
      });
    }
    // NUM must run first — later passes create \x00N\x00 placeholders whose
    // digit indices would otherwise be matched and corrupted by the NUM regex.
    mark(NUM, 'lh-num'); mark(CMT, 'lh-cmt'); mark(STR, 'lh-str');
    mark(KW,  'lh-kw');  mark(CMD, 'lh-cmd'); mark(VAR, 'lh-var');
    return out.replace(/\x00(\d+)\x00/g, function(_, i) { return spans[+i]; });
  }

  // ── Wrap each <pre> in .prose ─────────────────────────────────────────────
  document.querySelectorAll('#about-content .prose pre').forEach(function(pre) {
    var rawCode = pre.textContent;
    var wrapper = document.createElement('div');
    wrapper.className = 'logo-code-block';
    var header = document.createElement('div');
    header.className = 'logo-code-block-header';
    header.innerHTML = '<span>LOGO</span>' +
      '<button type="button" class="logo-code-block-toggle">⊞ Blocos</button>';
    var blocksPane = document.createElement('div');
    blocksPane.className = 'logo-code-block-blocks';
    blocksPane.dataset.code = rawCode;

    pre.innerHTML = highlightLogo(rawCode);
    pre.parentNode.insertBefore(wrapper, pre);
    wrapper.appendChild(header);
    wrapper.appendChild(pre);
    wrapper.appendChild(blocksPane);

    var toggleBtn = header.querySelector('button');
    var mode = 'code';
    toggleBtn.addEventListener('click', function() {
      if (mode === 'code') {
        mode = 'blocks';
        pre.style.display = 'none';
        blocksPane.style.display = 'block';
        toggleBtn.textContent = '< Código';
        toggleBtn.classList.add('blocks-active');
        if (!blocksPane.dataset.mounted) {
          blocksPane.dataset.mounted = '1';
          loadViewer(function() { window.LogoBlocksViewer.mount(blocksPane, rawCode); });
        } else {
          window.LogoBlocksViewer && window.LogoBlocksViewer.resize(blocksPane);
        }
      } else {
        mode = 'code';
        pre.style.display = '';
        blocksPane.style.display = 'none';
        toggleBtn.textContent = '⊞ Blocos';
        toggleBtn.classList.remove('blocks-active');
      }
    });
  });

  // ── Lazy-load viewer bundle ───────────────────────────────────────────────
  var _pending = [], _loading = false;
  function loadViewer(cb) {
    if (window.LogoBlocksViewer) { cb(); return; }
    _pending.push(cb);
    if (_loading) return;
    _loading = true;
    var s = document.createElement('script');
    s.src = '/editor-assets/js/logo-blocks-viewer.js';
    s.onload = function() { _pending.forEach(function(fn) { fn(); }); _pending = []; };
    document.head.appendChild(s);
  }
})();
</script>
