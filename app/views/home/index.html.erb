<div style="max-width:900px;margin:0 auto;padding:80px 32px 48px;text-align:center;">
  <h1 style="font-size:48px;font-weight:700;color:#0081A6;margin-bottom:12px;line-height:1.15;"><%= t("home.title") %></h1>
  <p style="font-size:18px;color:#929292;margin-bottom:32px;"><%= t("home.subtitle") %></p>

  <% if user_signed_in? %>
    <%= link_to t("home.new_project"), new_project_path, class: "btn-primary", style: "font-size:16px;padding:10px 28px;margin-right:12px;" %>
    <%= link_to t("home.about_link"), about_path, class: "btn-secondary", style: "font-size:16px;padding:10px 28px;" %>
  <% else %>
    <%= link_to t("home.get_started"), new_user_registration_path, class: "btn-primary", style: "font-size:16px;padding:10px 28px;margin-right:12px;" %>
    <%= link_to t("home.explore"), explore_path, class: "btn-secondary", style: "font-size:16px;padding:10px 28px;" %>
  <% end %>
</div>

<% if @featured_projects.any? %>
  <section style="max-width:1200px;margin:0 auto;padding:0 32px 80px;">
    <h2 style="font-size:22px;font-weight:700;color:#000;margin-bottom:24px;"><%= t("home.featured") %></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;">
      <% @featured_projects.each do |project| %>
        <div class="card-light overflow-hidden transition-shadow duration-150 hover:shadow-md" style="padding:0;">
          <% if project.thumbnail_url.present? %>
            <img src="<%= project.thumbnail_url %>" alt="" style="width:100%;height:160px;object-fit:cover;display:block;border-bottom:1px solid #e5e5e5;">
          <% else %>
            <div style="height:160px;background:#f8f9fb;display:flex;align-items:center;justify-content:center;border-bottom:1px solid #e5e5e5;">
              <span style="font-size:48px;">🐢</span>
            </div>
          <% end %>
          <div style="padding:12px 14px;">
            <p style="font-size:15px;font-weight:600;color:#000;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= project.title %></p>
            <p style="font-size:12px;color:#929292;margin-top:2px;"><%= t("common.by") %> <%= project.user.display %></p>
            <% if project.description.present? %>
              <p style="font-size:13px;color:#929292;margin-top:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= project.description %></p>
            <% end %>
            <div style="margin-top:10px;">
              <%= link_to t("home.view_project"), project_path(project), style: "font-size:13px;font-weight:700;color:#0081A6;text-decoration:none;" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

