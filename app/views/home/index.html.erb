<div class="max-w-4xl mx-auto px-4 py-16 text-center">
  <h1 class="text-5xl font-bold text-hf-blue mb-4"><%= t("home.title") %></h1>
  <p class="text-xl text-gray-600 mb-8"><%= t("home.subtitle") %></p>

  <% if user_signed_in? %>
    <%= link_to t("home.new_project"), new_project_path,
        class: "btn-primary text-lg px-8 py-3" %>
  <% else %>
    <%= link_to t("home.get_started"), new_user_registration_path,
        class: "btn-primary text-lg px-8 py-3 mr-4" %>
    <%= link_to t("home.explore"), explore_path,
        class: "btn-secondary text-lg px-8 py-3" %>
  <% end %>
</div>

<% if @featured_projects.any? %>
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">✦ Projetos em Destaque</h2>
    <div class="grid grid-cols-2 gap-4" style="grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));">
      <% @featured_projects.each do |project| %>
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
          <% if project.thumbnail_url.present? %>
            <img src="<%= project.thumbnail_url %>" alt="" class="w-full object-cover" style="height:160px;">
          <% else %>
            <div class="w-full flex items-center justify-center text-gray-300 text-4xl" style="height:160px;background:#f8f9fb;">🐢</div>
          <% end %>
          <div class="p-4">
            <h3 class="font-semibold text-gray-800 truncate"><%= project.title %></h3>
            <p class="text-sm text-gray-500 mt-0.5">por <%= project.user.display %></p>
            <% if project.description.present? %>
              <p class="text-sm text-gray-400 mt-1 line-clamp-2"><%= project.description %></p>
            <% end %>
            <div class="mt-3">
              <%= link_to "Ver projeto →", project_path(project), class: "text-sm text-hf-blue hover:underline" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
