<div class="flex items-center justify-center px-4 py-10" style="min-height:calc(100vh - 104px);background:#f8f8f8;">
  <div style="width:100%;max-width:400px;">

    <div class="text-center mb-6">
      <h1 style="font-size:24px;font-weight:700;color:#000;margin:0 0 4px;"><%= t("devise.sessions.new.title") %></h1>
      <p style="font-size:14px;color:#929292;margin:0;"><%= t("devise.sessions.new.subtitle") %></p>
    </div>

    <div class="card-light p-6">

      <% if resource.errors.any? %>
        <div style="margin-bottom:16px;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 12px;">
          <ul style="margin:0;padding-left:16px;font-size:13px;color:#D51414;">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Google OAuth %>
      <%= render "devise/shared/google_button" %>

      <div class="flex items-center gap-3 my-4">
        <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
        <span style="font-size:12px;color:#929292;"><%= t("common.or") %></span>
        <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="flex flex-col gap-3">

          <div>
            <%= f.label :email, t("common.email_label"), class: "form-label" %>
            <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "seu@email.com",
                class: "form-input" %>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <%= f.label :password, t("common.password_label"), class: "form-label", style: "margin-bottom:0;" %>
              <% if devise_mapping.recoverable? %>
                <%= link_to t("devise.sessions.new.forgot_password"), new_password_path(resource_name), style: "font-size:13px;color:#0081A6;text-decoration:none;" %>
              <% end %>
            </div>
            <%= f.password_field :password,
                autocomplete: "current-password",
                placeholder: "••••••••",
                class: "form-input" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me, t("devise.sessions.new.remember_me"), style: "font-size:13px;color:#929292;" %>
            </div>
          <% end %>

        </div>

        <div class="mt-4">
          <%= f.submit t("devise.sessions.new.sign_in"), class: "btn-primary w-full", style: "justify-content:center;" %>
        </div>
      <% end %>

    </div>

    <div class="mt-4 text-center flex flex-col gap-1.5">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
