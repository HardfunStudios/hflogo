<%- if controller_name != 'sessions' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to t("devise.shared.have_account"), new_session_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if controller_name != 'registrations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to t("devise.shared.create_account"), new_registration_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to t("devise.shared.forgot_password"), new_password_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to t("devise.shared.resend_confirmation"), new_confirmation_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>
