<%- if controller_name != 'sessions' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to "Já tem uma conta? Entrar", new_session_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if controller_name != 'registrations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to "Criar conta", new_registration_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="text-center text-sm text-gray-600">
    <%= link_to "Não recebeu as instruções de confirmação?", new_confirmation_path(resource_name), class: "text-hf-blue font-semibold hover:underline" %>
  </p>
<% end %>
