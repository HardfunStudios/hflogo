<div class="flex items-center justify-center px-4 py-10" style="min-height:calc(100vh - 104px);background:#f8f8f8;">
  <div style="width:100%;max-width:400px;">

    <div class="text-center mb-6">
      <h1 style="font-size:24px;font-weight:700;color:#000;margin:0 0 4px;">Criar conta</h1>
      <p style="font-size:14px;color:#929292;margin:0;">Comece a programar e compartilhar projetos</p>
    </div>

    <div class="card-light p-6">

      <% if resource.errors.any? %>
        <div style="margin-bottom:16px;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 12px;">
          <ul style="margin:0;padding-left:16px;font-size:13px;color:#D51414;">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Google OAuth %>
      <%= link_to user_google_oauth2_omniauth_authorize_path,
          method: :post,
          data: { turbo: false },
          style: "display:flex;align-items:center;justify-content:center;gap:10px;width:100%;height:40px;background:#fff;border:1px solid #DADCE0;border-radius:6px;font-size:14px;font-weight:500;color:#3C4043;text-decoration:none;box-sizing:border-box;transition:box-shadow .15s,background .15s;",
          onmouseover: "this.style.boxShadow='0 1px 3px rgba(0,0,0,.15)';this.style.background='#f8f9fa'",
          onmouseout: "this.style.boxShadow='none';this.style.background='#fff'" do %>
        <svg style="width:18px;height:18px;flex-shrink:0;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span style="font-family:'Roboto',sans-serif;">Continuar com Google</span>
      <% end %>

      <div class="flex items-center gap-3 my-4">
        <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
        <span style="font-size:12px;color:#929292;">ou</span>
        <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
      </div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="flex flex-col gap-3">

          <div>
            <%= f.label :email, "E-mail", class: "form-label" %>
            <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "seu@email.com",
                class: "form-input" %>
          </div>

          <div>
            <%= f.label :username, "Usuário", class: "form-label" %>
            <%= f.text_field :username,
                autocomplete: "username",
                placeholder: "ex: joaosilva123",
                class: "form-input" %>
            <p style="margin:3px 0 0;font-size:11px;color:#929292;">3–30 caracteres: letras minúsculas, números e _</p>
          </div>

          <div>
            <%= f.label :date_of_birth, "Data de nascimento", class: "form-label" %>
            <%= f.date_field :date_of_birth, class: "form-input" %>
          </div>

          <div>
            <%= f.label :password, "Senha", class: "form-label" %>
            <% if @minimum_password_length %>
              <p style="margin:-2px 0 4px;font-size:11px;color:#929292;">Mínimo <%= @minimum_password_length %> caracteres</p>
            <% end %>
            <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "form-input" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "form-input" %>
          </div>

        </div>

        <div class="mt-4">
          <%= f.submit "Criar conta", class: "btn-primary w-full", style: "justify-content:center;" %>
        </div>
      <% end %>

    </div>

    <div class="mt-4 text-center flex flex-col gap-1.5">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
