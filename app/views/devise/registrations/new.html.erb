<% google_signup = session["devise.google_data"].present? %>
<% content_for :ga_inline do %>
  if (typeof gtag !== 'undefined') gtag('event', 'sign_up_start', { method: '<%= google_signup ? "google" : "email" %>' });
<% end %>

<div class="flex items-center justify-center px-4 py-10" style="min-height:calc(100vh - 104px);background:#f8f8f8;">
  <div style="width:100%;max-width:400px;">

    <div class="text-center mb-6">
      <% if google_signup %>
        <h1 style="font-size:24px;font-weight:700;color:#000;margin:0 0 4px;">Quase lá!</h1>
        <p style="font-size:14px;color:#929292;margin:0;">Só precisamos de mais uma informação para criar sua conta</p>
      <% else %>
        <h1 style="font-size:24px;font-weight:700;color:#000;margin:0 0 4px;"><%= t("devise.registrations.new.title") %></h1>
        <p style="font-size:14px;color:#929292;margin:0;"><%= t("devise.registrations.new.subtitle") %></p>
      <% end %>
    </div>

    <div class="card-light p-6">

      <% if resource.errors.any? %>
        <div style="margin-bottom:16px;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 12px;">
          <ul style="margin:0;padding-left:16px;font-size:13px;color:#D51414;">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if google_signup %>
        <%# Modo completar cadastro via Google — pede só data de nascimento e confirma username %>
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="flex flex-col gap-3">

            <div>
              <%= f.label :email, t("common.email_label"), class: "form-label" %>
              <%= f.email_field :email, readonly: true, class: "form-input", style: "background:#f5f5f5;color:#929292;cursor:default;" %>
            </div>

            <div>
              <%= f.label :username, t("devise.registrations.new.username_label"), class: "form-label" %>
              <%= f.text_field :username, autocomplete: "username", placeholder: "ex: joaosilva123", class: "form-input" %>
              <p style="margin:3px 0 0;font-size:11px;color:#929292;"><%= t("devise.registrations.new.username_help") %></p>
            </div>

            <div>
              <%= f.label :date_of_birth, t("devise.registrations.new.date_of_birth_label"), class: "form-label" %>
              <%= f.date_field :date_of_birth, class: "form-input" %>
            </div>

          </div>

          <div class="mt-4">
            <%= f.submit "Criar conta com Google", class: "btn-primary w-full", style: "justify-content:center;" %>
          </div>
        <% end %>

      <% else %>
        <%# Cadastro normal %>
        <%= render "devise/shared/google_button" %>

        <div class="flex items-center gap-3 my-4">
          <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
          <span style="font-size:12px;color:#929292;"><%= t("common.or") %></span>
          <div style="flex:1;border-top:1px solid #e5e5e5;"></div>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="flex flex-col gap-3">

            <div>
              <%= f.label :email, t("common.email_label"), class: "form-label" %>
              <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  placeholder: "seu@email.com",
                  class: "form-input" %>
            </div>

            <div>
              <%= f.label :username, t("devise.registrations.new.username_label"), class: "form-label" %>
              <%= f.text_field :username,
                  autocomplete: "username",
                  placeholder: "ex: joaosilva123",
                  class: "form-input" %>
              <p style="margin:3px 0 0;font-size:11px;color:#929292;"><%= t("devise.registrations.new.username_help") %></p>
            </div>

            <div>
              <%= f.label :date_of_birth, t("devise.registrations.new.date_of_birth_label"), class: "form-label" %>
              <%= f.date_field :date_of_birth, class: "form-input" %>
            </div>

            <div>
              <%= f.label :password, t("common.password_label"), class: "form-label" %>
              <% if @minimum_password_length %>
                <p style="margin:-2px 0 4px;font-size:11px;color:#929292;"><%= t("devise.registrations.new.password_help", count: @minimum_password_length) %></p>
              <% end %>
              <%= f.password_field :password,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "form-input" %>
            </div>

            <div>
              <%= f.label :password_confirmation, t("devise.registrations.new.password_confirmation_label"), class: "form-label" %>
              <%= f.password_field :password_confirmation,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "form-input" %>
            </div>

          </div>

          <div class="mt-4">
            <%= f.submit t("devise.registrations.new.sign_up"), class: "btn-primary w-full", style: "justify-content:center;" %>
          </div>
        <% end %>
      <% end %>

    </div>

    <div class="mt-4 text-center flex flex-col gap-1.5">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
