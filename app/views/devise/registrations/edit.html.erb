<div style="min-height:calc(100vh - 72px);background:#f9fafb;padding:40px 16px;">
  <div style="width:100%;max-width:480px;margin:0 auto;">

    <div style="margin-bottom:24px;">
      <h1 style="font-size:22px;font-weight:700;color:#111827;margin:0 0 4px;"><%= t("devise.registrations.edit.title") %></h1>
      <p style="font-size:13px;color:#6b7280;margin:0;"><%= t("devise.registrations.edit.subtitle") %></p>
    </div>

    <div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.06);padding:24px;">

      <% if resource.errors.any? %>
        <div style="margin-bottom:16px;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 12px;">
          <ul style="margin:0;padding-left:16px;font-size:12px;color:#dc2626;">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

        <p style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin:0 0 12px;"><%= t("devise.registrations.edit.account_section") %></p>

        <div style="display:flex;flex-direction:column;gap:12px;">

          <div>
            <%= f.label :email, t("common.email_label"), style: "display:block;font-size:12px;font-weight:500;color:#374151;margin-bottom:4px;" %>
            <%= f.email_field :email,
                autocomplete: "email",
                style: "width:100%;border:1px solid #d1d5db;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;box-sizing:border-box;outline:none;" %>
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p style="margin:3px 0 0;font-size:11px;color:#d97706;"><%= t("devise.registrations.edit.pending_confirmation") %> <%= resource.unconfirmed_email %></p>
            <% end %>
          </div>

          <div>
            <%= f.label :username, t("devise.registrations.edit.username_label"), style: "display:block;font-size:12px;font-weight:500;color:#374151;margin-bottom:4px;" %>
            <%= f.text_field :username,
                autocomplete: "username",
                style: "width:100%;border:1px solid #d1d5db;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;box-sizing:border-box;outline:none;" %>
          </div>

        </div>

        <hr style="border:none;border-top:1px solid #f3f4f6;margin:20px 0;">

        <p style="font-size:11px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:.05em;margin:0 0 12px;">
          <%= t("devise.registrations.edit.change_password_section") %> <span style="font-weight:400;text-transform:none;letter-spacing:0;"><%= t("devise.registrations.edit.leave_blank_hint") %></span>
        </p>

        <div style="display:flex;flex-direction:column;gap:12px;">

          <div>
            <%= f.label :password, t("devise.registrations.edit.new_password_label"), style: "display:block;font-size:12px;font-weight:500;color:#374151;margin-bottom:4px;" %>
            <% if @minimum_password_length %>
              <p style="margin:-2px 0 4px;font-size:11px;color:#9ca3af;"><%= t("devise.registrations.edit.password_help", count: @minimum_password_length) %></p>
            <% end %>
            <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "••••••••",
                style: "width:100%;border:1px solid #d1d5db;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;box-sizing:border-box;outline:none;" %>
          </div>

          <div>
            <%= f.label :password_confirmation, t("devise.registrations.edit.password_confirmation_label"), style: "display:block;font-size:12px;font-weight:500;color:#374151;margin-bottom:4px;" %>
            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "••••••••",
                style: "width:100%;border:1px solid #d1d5db;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;box-sizing:border-box;outline:none;" %>
          </div>

        </div>

        <hr style="border:none;border-top:1px solid #f3f4f6;margin:20px 0;">

        <div>
          <%= f.label :current_password, t("devise.registrations.edit.current_password_label"), style: "display:block;font-size:12px;font-weight:500;color:#374151;margin-bottom:4px;" %>
          <p style="margin:-2px 0 4px;font-size:11px;color:#9ca3af;"><%= t("devise.registrations.edit.current_password_hint") %></p>
          <%= f.password_field :current_password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              style: "width:100%;border:1px solid #d1d5db;border-radius:6px;padding:8px 10px;font-size:13px;color:#111827;box-sizing:border-box;outline:none;" %>
        </div>

        <div style="margin-top:20px;">
          <%= f.submit t("devise.registrations.edit.save_button"), class: "btn-primary", style: "padding:9px 20px;font-size:14px;cursor:pointer;" %>
        </div>

      <% end %>

    </div>

    <div style="background:#fff;border:1px solid #fecaca;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.06);padding:20px 24px;margin-top:16px;">
      <h2 style="font-size:13px;font-weight:600;color:#dc2626;margin:0 0 4px;"><%= t("devise.registrations.edit.danger_zone_title") %></h2>
      <p style="font-size:12px;color:#6b7280;margin:0 0 14px;"><%= t("devise.registrations.edit.danger_zone_message") %></p>
      <%= button_to t("devise.registrations.edit.delete_button"), registration_path(resource_name),
          data: { turbo_confirm: t("devise.registrations.edit.delete_confirm") },
          method: :delete,
          class: "btn-danger",
          style: "padding:7px 14px;font-size:13px;cursor:pointer;" %>
    </div>

  </div>
</div>
