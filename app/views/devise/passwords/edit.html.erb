<div class="flex items-center justify-center px-4 py-10" style="min-height:calc(100vh - 104px);background:#f8f8f8;">
  <div style="width:100%;max-width:400px;">

    <div class="text-center mb-6">
      <h1 style="font-size:24px;font-weight:700;color:#000;margin:0 0 4px;">Nova senha</h1>
      <p style="font-size:14px;color:#929292;margin:0;">Escolha uma senha segura para sua conta</p>
    </div>

    <div class="card-light p-6">

      <% if resource.errors.any? %>
        <div style="margin-bottom:16px;background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:10px 12px;">
          <ul style="margin:0;padding-left:16px;font-size:13px;color:#D51414;">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div class="flex flex-col gap-3">

          <div>
            <%= f.label :password, "Nova senha", class: "form-label" %>
            <% if @minimum_password_length %>
              <p style="margin:-2px 0 4px;font-size:11px;color:#929292;">Mínimo <%= @minimum_password_length %> caracteres</p>
            <% end %>
            <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "form-input" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmar nova senha", class: "form-label" %>
            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "form-input" %>
          </div>

        </div>

        <div class="mt-4">
          <%= f.submit "Redefinir senha", class: "btn-primary w-full", style: "justify-content:center;" %>
        </div>

      <% end %>

    </div>

    <div class="mt-4 text-center flex flex-col gap-1.5">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
