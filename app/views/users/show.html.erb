<% content_for :title, "@#{@user.username} — Logo" %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-start gap-6 mb-8">
    <div class="w-20 h-20 rounded-full bg-hf-blue text-white flex items-center justify-center text-3xl font-bold flex-shrink-0">
      <%= @user.display.first.upcase %>
    </div>
    <div>
      <h1 class="text-2xl font-bold"><%= @user.display %></h1>
      <p class="text-gray-500">@<%= @user.username %></p>
      <% if @user.bio.present? %>
        <p class="mt-2 text-gray-700"><%= @user.bio %></p>
      <% end %>
    </div>
  </div>

  <h2 class="text-xl font-bold mb-4"><%= t("users.projects_heading") %></h2>
  <% if @projects.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <%= render partial: "projects/card", collection: @projects %>
    </div>
  <% else %>
    <p class="text-gray-500"><%= t("users.no_projects") %></p>
  <% end %>
</div>
